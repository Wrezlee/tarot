<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="#E1AFD1"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tvItemPackage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9 Kartu Deep Reading"
                android:textColor="#7469B6"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvItemStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_status_rounded"
                android:backgroundTint="#F3E5F5"
                android:paddingHorizontal="8dp"
                android:text="DONE"
                android:textColor="#AD88C6"
                android:textSize="10sp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvItemDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="12 April 2026"
            android:textColor="#80251819"
            android:textSize="11sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#FFE6E6" />

        <TextView
            android:id="@+id/tvItemQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Q: Bagaimana karir saya?"
            android:textColor="#251819"
            android:textSize="12sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/tvItemAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="A: Belum ada jawaban dari Reader."
            android:textColor="#AD88C6"
            android:textSize="12sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
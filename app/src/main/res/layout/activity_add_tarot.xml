<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFE6E6"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:fontFamily="serif"
        android:text="TAMBAH PAKET"
        android:textColor="#7469B6"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Buat paket ritual tarot baru untuk pelanggan."
        android:textColor="#AD88C6"
        android:textSize="12sp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="#FFFFFF"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeColor="#E1AFD1"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Layanan Tarot"
                android:textColor="#AD88C6"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etTarotName"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@android:color/transparent"
                android:hint="Contoh: Reading 3 Kartu"
                android:inputType="textCapWords"
                android:textColor="#251819"
                android:textSize="16sp" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3E5F5" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Kategori"
                android:textColor="#AD88C6"
                android:textSize="12sp"
                android:textStyle="bold" />
            <AutoCompleteTextView
                android:id="@+id/actvCategory"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@android:color/transparent"
                android:hint="Ketik T atau C..."
                android:completionThreshold="1"
                android:textColor="#251819"
                android:textSize="16sp" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3E5F5" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Biaya Layanan (Rp)"
                android:textColor="#AD88C6"
                android:textSize="12sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etTarotPrice"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@android:color/transparent"
                android:hint="Masukkan nominal"
                android:inputType="number"
                android:textColor="#251819"
                android:textSize="16sp" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F3E5F5" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveTarot"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginTop="32dp"
        android:text="SIMPAN PAKET"
        android:textStyle="bold"
        app:backgroundTint="#7469B6"
        app:cornerRadius="16dp" />

</LinearLayout>